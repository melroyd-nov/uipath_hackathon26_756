# ===========================================================================
# call_analytics_app — environment template
#
# JUDGES: copy this file to `.env` (same folder) and fill in the two SECRETS
# marked "← YOU SUPPLY" below. Everything else — including the prompts and the
# compliance rubric — is filled in for you and works as-is.
#
#     cd call_analytics_app
#     Copy-Item .env.example .env      # PowerShell   (bash: cp .env.example .env)
#
# The prompts / rubric used to be proprietary and kept out of the repo. For the
# hackathon judging we are sharing them here so the local agent runs end-to-end.
# ===========================================================================

# --- SECRETS (you supply) --------------------------------------------------

# Hugging Face token — needed to download the *gated* pyannote diarization model.
# ← YOU SUPPLY. It's free:
#   1) create an account at https://huggingface.co
#   2) accept the model conditions (one click each) at
#        https://huggingface.co/pyannote/speaker-diarization-3.1
#        https://huggingface.co/pyannote/segmentation-3.0
#   3) make a READ token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxx

# Shared secret the local server requires in the X-API-Key header.
# ← YOU SUPPLY any random string. Generate one:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# For the full cloud round-trip, put this same value in the UiPath Secret asset
# `call-analytics-api-key` (see the README "For judges" section).
API_KEY=

# --- LLM provider ----------------------------------------------------------
# "ollama" (local, default, fully offline) or "anthropic" (hosted).
LLM_PROVIDER=ollama

# Ollama (local) — `ollama pull llama3.2` then `ollama pull qwen2.5:7b`
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
# Stronger model just for compliance/rollup judgments (optional).
JUDGE_MODEL=qwen2.5:7b

# Anthropic (hosted) — only when LLM_PROVIDER=anthropic. Lets you skip Ollama for
# the LLM stages (the audio models below still run locally). Supply your own key.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# --- audio models / runtime ------------------------------------------------
# "cuda" if you have an NVIDIA GPU (recommended); "cpu" works but is much slower.
DEVICE=cuda
MAX_UPLOAD_MB=50
# Unbounded queue: hold every request until its turn (never 503); 1 at a time on GPU.
API_MAX_QUEUE=-1

# ===========================================================================
# PROMPTS & RUBRIC — shared for judging. \n = line break (expanded on load);
# keep the {placeholders} intact.
# ===========================================================================

# --- LLM prompt templates ---
JUDGE_PROMPT="You are a compliance auditor for financial/banking call centers. Decide whether the RULE is satisfied in the role-labeled TRANSCRIPT. Answer PASS (clearly satisfied), FAIL (clearly violated), or NA (not enough evidence). Quote brief evidence and give a one-line reason.\n\nRULE: {rule}\n\nTRANSCRIPT:\n{transcript}"

FOLLOWUP_PROMPT="Decide whether THIS call references a PRIOR interaction (a previous call, ticket, an agent spoken to before, or an earlier request) — i.e. it is a follow-up — based ONLY on the transcript. Cues: 'as I mentioned', 'last time', 'called yesterday', ticket numbers, a previously-named agent/manager.\n\nTRANSCRIPT:\n{transcript}"

ROLE_PROMPT="Below is the start of a call-center phone transcript with anonymous speaker labels ({labels}). Identify which label is the SUPPORT AGENT and which is the CUSTOMER. Use the labels exactly as written.\n\n{snippet}"

ROLLUP_PROMPT="Analyze this call-center transcript and produce: a concise summary (1-2 sentences), the caller intent (short phrase), the resolution (resolved / unresolved / follow_up_needed), the fraud risk (low / medium / high), and a short fraud reason.\n\nTRANSCRIPT:\n{transcript}"

SENT_PROMPT="Score the sentiment of this call-center utterance as an integer from -2 (very negative) to +2 (very positive), 0 = neutral.\n\nUTTERANCE: {text}"

FOLLOWUP_ACTIONS_PROMPT="You are a call-center supervisor assistant. From the transcript below — where the caller intent was '{intent}' and the call ended '{resolution}' — list 0 to 3 concrete next-step action items the team should take after this call. Each item is a short imperative sentence. Return an empty list if the call was fully handled and needs no follow-up.\n\nTRANSCRIPT:\n{transcript}"

IDENTITY_PROMPT="You are an insurance call-center compliance assistant. From the transcript below, extract the caller's identity details exactly as the CUSTOMER states them aloud during verification. Only use values explicitly spoken in the call — never guess, infer, or fabricate. For any value that is not stated, return the literal string 'NA'.\n\nReturn:\n- nric: the national ID / NRIC as stated (e.g. S1234567A), or 'NA'\n- dob: the date of birth as stated (e.g. 12 March 1985), or 'NA'\n- policy_number: the insurance policy number as stated, or 'NA'\n\nTRANSCRIPT:\n{transcript}"

# --- Compliance rubric rule texts (judged independently: PASS / FAIL / NA) ---
RUBRIC_PURPOSE_DISCLOSURE="The agent identified themselves (name/company) and stated the purpose of the call."
RUBRIC_RECORDING_DISCLOSURE="The agent disclosed that the call may be recorded or monitored."
RUBRIC_IDENTITY_VERIFICATION="The agent verified the customer's identity before discussing account-specific details."
RUBRIC_NO_GUARANTEES="The agent did NOT promise guaranteed investment returns, profits, or financial outcomes. Routine service commitments — processing a refund, escalating or reviewing a complaint, scheduling a callback, reprocessing a claim if an investigation confirms an error — are normal and are NOT prohibited guarantees; judge those as PASS."
RUBRIC_NO_SENSITIVE_DATA_INSECURE="No full card/account numbers, PINs, OTPs, or passwords were solicited or read aloud."
RUBRIC_NO_REMOTE_ACCESS="The agent did NOT instruct the customer to install remote-access software (AnyDesk/TeamViewer) or grant device/screen control."
RUBRIC_NO_FUND_MOVEMENT="The agent did NOT pressure the customer to move, withdraw, or transfer money to 'verify' or 'secure' it."
RUBRIC_PROFESSIONAL_CONDUCT="The agent remained professional, non-abusive, and non-misleading throughout."
