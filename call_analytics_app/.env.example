# Copy to .env (or rely on the project-root .env which already has HF_TOKEN).

# Hugging Face token (gated pyannote repos). Loaded from project-root .env by default.
HF_TOKEN=hf_xxx

# LLM provider: "ollama" (local, default) or "anthropic" (hosted)
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (hosted) — only needed when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: a stronger model just for compliance/rollup judgments (e.g. qwen2.5:7b)
# JUDGE_MODEL=qwen2.5:7b

# Device for audio models
DEVICE=cuda

# --- API server security ---
# Shared secret required in the X-API-Key header on POST /analyze.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
# The UiPath cloud agent must send this same value as the X-API-Key header.
API_KEY=

# Reject uploads larger than this many MB
MAX_UPLOAD_MB=50

# ---------------------------------------------------------------------------
# PROPRIETARY PROMPTS & RUBRIC — required at runtime, NEVER commit real values.
# Fill these in your local .env. Prompts use \n for line breaks (expanded on
# load); keep the {placeholders} intact.
# ---------------------------------------------------------------------------
# LLM prompt templates
JUDGE_PROMPT=""
FOLLOWUP_PROMPT=""
ROLE_PROMPT=""
ROLLUP_PROMPT=""
SENT_PROMPT=""
FOLLOWUP_ACTIONS_PROMPT=""
# Compliance rule texts (one per rule id)
RUBRIC_PURPOSE_DISCLOSURE=""
RUBRIC_RECORDING_DISCLOSURE=""
RUBRIC_IDENTITY_VERIFICATION=""
RUBRIC_NO_GUARANTEES=""
RUBRIC_NO_SENSITIVE_DATA_INSECURE=""
RUBRIC_NO_REMOTE_ACCESS=""
RUBRIC_NO_FUND_MOVEMENT=""
RUBRIC_PROFESSIONAL_CONDUCT=""
