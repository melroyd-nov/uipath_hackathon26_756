# Local ML pipeline — machine-specific / generated artifacts (never commit)

# Python env & caches
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# Secrets / local config
.env
.claude/

# UiPath build/state (regenerated by `uipath init` / pack)
.uipath/
__uipath/
*.nupkg
*.db

# Pipeline run outputs (regenerated per run)
outputs/
