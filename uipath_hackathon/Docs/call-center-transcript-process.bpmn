<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_CCAnalytics_Full" targetNamespace="http://Acme.com/cc-analytics/uipath" exporter="UiPath (https://bpmn.uipath.com)" exporterVersion="a0f9348b">
  <bpmn:collaboration id="Collaboration_CC_Full">
    <bpmn:extensionElements>
      <uipath:migrationVersion version="11.5" />
    </bpmn:extensionElements>
    <bpmn:participant id="Pool_CC" name="Acme — Call Center Analytics (End-to-End)" processRef="Process_CC_Full" />
  </bpmn:collaboration>
  <bpmn:process id="Process_CC_Full" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_System" name="Automated System (FastAPI / UiPath)">
        <bpmn:flowNodeRef>Start_CallReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecordCall</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IngestTranscript</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AIParallelFork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AIParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StoreCallRecord</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SeedFollowups</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HasFollowups</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateDashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AnalyticsFork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SentimentAnalytics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EscalationAnalytics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComplianceAnalytics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AnalyticsJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Complete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AI" name="UiPath Generative AI Service">
        <bpmn:flowNodeRef>Task_ExtractSentiment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClassifyIntents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DetectTriggerWords</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckCompliance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GenFollowups</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DetermineResolution</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GenSummary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ResolutionAnalytics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IntentAnalytics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FrictionAnalytics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GenerateAIResponse</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Supervisor" name="Supervisor / Manager">
        <bpmn:flowNodeRef>Task_SupervisorReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ApproveReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssignDetails</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RejectFollowup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TrackProgress</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ProgressStatus</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MarkCompleted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QueryAI</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_CallReceived" name="JSON Analysis Result Arrives">
      <bpmn:documentation>
        TRIGGER: Friend's analysis system produces a JSON file per call recording.
        INPUT: JSON object containing transcript analysis results (not raw .txt).
        JSON TOP-LEVEL FIELDS:
          recording (string): MP3 filename
          duration_sec (decimal): Call duration
          summary (string): Call summary
          intent (string): Single call intent
          resolution (string): "resolved" or "unresolved"
          fraud_risk (string): Risk level
          fraud_reason (string): Risk explanation
          is_followup (boolean): Is this a follow-up call?
          followup_evidence (string): Why it is/isn't a follow-up
          sentiment_avg {agent, customer} (decimal): Sentiment scores
          talk_ratio_pct {AGENT, CUSTOMER} (decimal): Talk time %
          audio_emotion {AGENT, CUSTOMER} (string): Audio emotion
          compliance (array): 8 compliance rules with PASS/FAIL/NA
          compliance_violations (array): Failed rule IDs
          pii_digits_detected (boolean): PII detection flag
          triggers (array): Trigger events with timestamps
        
        This JSON is fed into the Flow, which maps fields to Data Fabric CallRecord.
        The 7 parallel branches extract/process different sections of the JSON.
        
        DATA FABRIC ENTITIES:
          - CallRecord (beac40ee-bd6b-f111-8fcb-000d3ab36606)
          - CallFollowup (993c2c06-be6b-f111-8fcb-000d3ab36606)
          - AiUsage (45af032d-bb6b-f111-8fcb-000d3ab36606)
      </bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:entryPointId value="c76ae006-619b-4257-8fac-4eee852c97c8" />
      </bpmn:extensionElements>
      <bpmn:outgoing>F_Start_Record</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_RecordCall" name="Receive JSON Analysis from Friend's System">
      <bpmn:documentation>
        WHAT: Friend's analysis system processes call recording (MP3) and produces JSON.
        INPUT: Call recording file (e.g. tmpi70znh6_.mp3)
        OUTPUT: JSON analysis file with fields:
          recording, duration_sec, summary, intent, resolution, fraud_risk,
          fraud_reason, is_followup, followup_evidence, sentiment_avg,
          talk_ratio_pct, audio_emotion, compliance, compliance_violations,
          pii_digits_detected, triggers.
        DELIVERY: JSON dropped to Orchestrator Storage Bucket or sent via API.
        UIPATH FLOW: Trigger fires on JSON arrival, passes to Ingest node.
      </bpmn:documentation>
      <bpmn:incoming>F_Start_Record</bpmn:incoming>
      <bpmn:outgoing>F_Record_Ingest</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_IngestTranscript" name="Ingest JSON Analysis Result">
      <bpmn:documentation>
        SOURCE: Friend's analysis system — JSON file per call recording.
        INPUT: JSON object (see Start_CallReceived documentation for full field list).
        STEPS:
          1. Read JSON file from Storage Bucket or receive via webhook/API.
          2. Parse JSON into structured object.
          3. Validate required fields exist (recording, duration_sec, compliance array).
          4. Extract metadata: recording filename, duration.
          5. Pass JSON object to parallel fork for field extraction.
        OUTPUT: JSON object ready for 7 parallel extraction branches.
        NOTE: Unlike original design which parsed raw .txt transcripts,
          this flow receives PRE-ANALYZED JSON. The AI/ML work is done
          by friend's system; UiPath Flow maps JSON fields to Data Fabric.
      </bpmn:documentation>
      <bpmn:incoming>F_Record_Ingest</bpmn:incoming>
      <bpmn:outgoing>F_Ingest_AIFork</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_AIParallelFork" name="Fan-out: 7 Parallel JSON Field Extraction Branches">
      <bpmn:documentation>
        WHAT: Dispatches JSON object simultaneously to 7 extraction/processing branches.
        INPUT: Friend's analysis JSON (pre-computed transcript analysis).
        WHY: Parallel processing maximises throughput. All 7 branches read from
          the same JSON object — no external AI calls needed here.
        BRANCHES:
          1. Sentiment + Audio Emotion  ← sentiment_avg + audio_emotion
          2. Intent Classification      ← intent
          3. Trigger Events + PII       ← triggers[] + pii_digits_detected
          4. Compliance Rules           ← compliance[] + compliance_violations[]
          5. Follow-up Detection        ← is_followup + followup_evidence
          6. Resolution + Fraud Risk    ← resolution + fraud_risk + fraud_reason
          7. Summary + Talk Ratio       ← summary + talk_ratio_pct + duration_sec + recording
        SYNCHRONISATION: GW_AIParallelJoin waits for all 7 before Data Fabric write.
      </bpmn:documentation>
      <bpmn:incoming>F_Ingest_AIFork</bpmn:incoming>
      <bpmn:outgoing>F_Fork_Sentiment</bpmn:outgoing>
      <bpmn:outgoing>F_Fork_Intents</bpmn:outgoing>
      <bpmn:outgoing>F_Fork_TriggerWords</bpmn:outgoing>
      <bpmn:outgoing>F_Fork_Compliance</bpmn:outgoing>
      <bpmn:outgoing>F_Fork_Followups</bpmn:outgoing>
      <bpmn:outgoing>F_Fork_Resolution</bpmn:outgoing>
      <bpmn:outgoing>F_Fork_Summary</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:parallelGateway id="GW_AIParallelJoin" name="Synchronise: All 7 JSON Branches Complete">
      <bpmn:documentation>
        WHAT: Waits for all 7 JSON field extraction branches before advancing.
        WHY: Prevents partial records in Data Fabric. All CallRecord fields
          must be populated in one atomic insert via records.insert.
        BRANCHES WAITED FOR: sentiment, intents, triggers, compliance,
          follow-up detection, resolution/fraud, summary/talk ratio.
        OUTPUT: Aggregated result object passed to Task_StoreCallRecord for
          single atomic Data Fabric write.
      </bpmn:documentation>
      <bpmn:incoming>F_Sentiment_Join</bpmn:incoming>
      <bpmn:incoming>F_Intents_Join</bpmn:incoming>
      <bpmn:incoming>F_TriggerWords_Join</bpmn:incoming>
      <bpmn:incoming>F_Compliance_Join</bpmn:incoming>
      <bpmn:incoming>F_Followups_Join</bpmn:incoming>
      <bpmn:incoming>F_Resolution_Join</bpmn:incoming>
      <bpmn:incoming>F_Summary_Join</bpmn:incoming>
      <bpmn:outgoing>F_Join_StoreRecord</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_StoreCallRecord" name="Persist Call Record to Data Fabric — Atomic Insert">
      <bpmn:documentation>
        PRODUCT: Data Fabric (Native Entity)
        ENTITY: CallRecord
        ENTITY ID: beac40ee-bd6b-f111-8fcb-000d3ab36606
        PRIMARY KEY: System Id (UUID auto-generated by Data Fabric)
        BUSINESS KEY: callid (STRING(20), isUnique=true, required) — telephony correlation ID
        OPERATION: records.insert — single atomic write of ALL fields after AIParallelJoin.
          Partial writes are prevented by the join: all 7 JSON branches must complete first.
        FIELD COUNT: 27 original + ~10 NEW JSON fields = 37+ total
        
        ORIGINAL FIELDS (from header + AI):
          callid, call_date, call_start_time, call_end_time,
          caller_name, caller_nric, caller_dob, caller_number, agent_name, policy_number,
          call_sentiment (INTEGER), call_intent1/2/3 (STRING 100),
          followup_item1/2/3 (STRING 100),
          escalation_flag, compliance_flag, call_resolved_flag, preverified_flag,
          triggerword_flag (CHOICE_SET_SINGLE → YesNoFlag),
          triggerwords (STRING 100), call_summary (MULTILINE_TEXT 10000),
          file_name (STRING 100), repeatcall_flag (CHOICE_SET_SINGLE),
          transcript (MULTILINE_TEXT 10000).
        
        NEW FIELDS FROM FRIEND'S JSON (to add to CallRecord entity):
          agent_sentiment (DECIMAL)      ← sentiment_avg.agent
          customer_sentiment (DECIMAL)   ← sentiment_avg.customer
          agent_audio_emotion (STRING 20)   ← audio_emotion.agent
          customer_audio_emotion (STRING 20)← audio_emotion.customer
          agent_talk_pct (DECIMAL)       ← talk_ratio_pct.AGENT
          customer_talk_pct (DECIMAL)    ← talk_ratio_pct.CUSTOMER
          duration_seconds (DECIMAL)     ← duration_sec
          fraud_risk (STRING 20)         ← fraud_risk
          fraud_reason (MULTILINE_TEXT)  ← fraud_reason
          pii_digits_detected (CHOICE_SET_SINGLE → YesNoFlag) ← pii_digits_detected
          is_followup_call (CHOICE_SET_SINGLE → YesNoFlag) ← is_followup
          followup_call_evidence (MULTILINE_TEXT) ← followup_evidence
          compliance_detail (MULTILINE_TEXT 10000) ← full compliance JSON
          compliance_fail_count (INTEGER) ← compliance_violations.length
          trigger_count (INTEGER)        ← triggers.length
        
        CHOICE SET VALUES (YesNoFlag): Yes(NumberId=0), No(NumberId=1)
        DATA FABRIC QUERY: records.query with filterGroup on any field; groupBy + aggregates for KPIs.
        CONFLICT HANDLING: callid isUnique=true prevents duplicates.
      </bpmn:documentation>
      <bpmn:incoming>F_Join_StoreRecord</bpmn:incoming>
      <bpmn:outgoing>F_StoreRecord_SeedFollowups</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SeedFollowups" name="Seed AI Follow-ups into Data Fabric CallFollowup">
      <bpmn:documentation>
        PRODUCT: Data Fabric (Native Entity)
        ENTITY: CallFollowup
        ENTITY ID: 993c2c06-be6b-f111-8fcb-000d3ab36606
        PARENT ENTITY: CallRecord (beac40ee-bd6b-f111-8fcb-000d3ab36606)
        LOGIC:
          1. Read CallRecord just inserted; inspect followup_item1, followup_item2, followup_item3.
          2. Also check CallRecord.is_followup_call — if Yes, this call was itself
             a follow-up to a prior interaction (from JSON is_followup field).
          3. For each non-empty followup_itemN:
             a. Query CallFollowup to check if an ai_generated row exists for this callid + text.
             b. If NOT: insert new CallFollowup row:
                - callid = CallRecord.callid (STRING, required)
                - call_record = RELATIONSHIP → CallRecord (system Id UUID)
                - text = followup_itemN (STRING 500, required)
                - reason = keyword-extracted snippet from transcript (MULTILINE_TEXT 2000)
                - source = CHOICE_SET_SINGLE → FollowupSource, value = ai_generated (NumberId=0)
                - status = CHOICE_SET_SINGLE → FollowupStatus, value = pending (NumberId=0)
                - priority, assigned_to, due_date = null (set later by supervisor)
          4. If row exists but reason is empty: update reason field only.
        CHOICE SETS:
          - FollowupSource: ai_generated(0), manual(1)
          - FollowupStatus: pending(0), approved(1), rejected(2), in_progress(3), completed(4)
          - FollowupPriority: low(0), medium(1), high(2)
        RELATIONSHIP: call_record field is RELATIONSHIP type pointing to CallRecord.
        DEDUP: Unique constraint on (callid + text + source=ai_generated) enforced by Flow logic.
      </bpmn:documentation>
      <bpmn:incoming>F_StoreRecord_SeedFollowups</bpmn:incoming>
      <bpmn:outgoing>F_Seed_HasFollowupsGW</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_HasFollowups" name="Were Follow-up Action Items Generated?">
      <bpmn:documentation>
        CONDITION: At least one of CallRecord.followup_item1/2/3 is non-null and non-empty.
        YES path: supervisor review workflow needed (Task_SupervisorReview).
        NO path:  skip to dashboard refresh (purely informational calls).
        WHY: Prevents empty workflow tasks for calls with no outstanding commitments.
        DATA FABRIC: Condition checked by Flow expression reading the just-inserted CallRecord.
      </bpmn:documentation>
      <bpmn:incoming>F_Seed_HasFollowupsGW</bpmn:incoming>
      <bpmn:outgoing>F_HasFollowups_Yes</bpmn:outgoing>
      <bpmn:outgoing>F_HasFollowups_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_UpdateDashboard" name="Refresh Analytics Dashboard — 8 KPI Summary">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallRecord entity (beac40ee-bd6b-f111-8fcb-000d3ab36606)
        QUERY METHOD: records.query with aggregates and groupBy (no SQL — Data Fabric native).
        8 KPI METRICS (Data Fabric aggregations):
          total_calls         = COUNT(Id)
          avg_sentiment       = AVG(call_sentiment)  range -1.0 to +1.0
          escalation_pct      = 100 * COUNT(escalation_flag=Yes) / COUNT(Id)
          compliance_fail_pct = 100 * COUNT(compliance_flag=No) / COUNT(Id)
          resolution_pct      = 100 * COUNT(call_resolved_flag=Yes) / COUNT(Id)
          preverified_pct     = 100 * COUNT(preverified_flag=Yes) / COUNT(Id)
          trigger_word_pct    = 100 * COUNT(triggerword_flag=Yes) / COUNT(Id)
          repeat_call_pct     = 100 * COUNT(repeatcall_flag=Yes) / COUNT(Id)
        BENCHMARKS (from backend/config.py, preserved in dashboard code):
          escalation_pct      must be less than or equal to 10.0%
          compliance_fail_pct must be less than or equal to  5.0%
          resolution_pct      must be greater than or equal to 80.0%
          preverified_pct     must be greater than or equal to 80.0%
          trigger_word_pct    must be less than or equal to  3.0%
          repeat_call_pct     must be less than or equal to 20.0%
        Coded App: RAG (Red/Amber/Green) indicators vs benchmarks.
        ALSO REFRESHES:
          KPI trends    — groupBy call_date (YYYY-MM) + aggregates
          Agent summary — groupBy agent_name + all KPI aggregates + avg duration
      </bpmn:documentation>
      <bpmn:incoming>F_HasFollowups_No</bpmn:incoming>
      <bpmn:incoming>F_Reject_UpdateDashboard</bpmn:incoming>
      <bpmn:incoming>F_Progress_Active</bpmn:incoming>
      <bpmn:incoming>F_Completed_UpdateDashboard</bpmn:incoming>
      <bpmn:outgoing>F_UpdateDashboard_AnalyticsFork</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_AnalyticsFork" name="Fan-out: 6 Analytics Modules in Parallel">
      <bpmn:documentation>
        WHAT: Six analytics modules run simultaneously to power dashboard charts.
        All query call_records via analytics_service.py. All endpoints under /api/analytics/*.
        Results are JSON consumed by UiPath Apps visualisations.
        MODULES:
          1. Sentiment Analytics   (System lane) — 3 endpoints
          2. Escalation Analytics  (System lane) — 3 endpoints incl. root-cause
          3. Compliance Analytics  (System lane) — 2 endpoints
          4. Resolution Analytics  (AI lane)     — 5 endpoints incl. repeat calls
          5. Intent Analytics      (AI lane)     — 3 endpoints incl. marketing opps
          6. Friction Points       (AI lane)     — 3 endpoints incl. trigger words
      </bpmn:documentation>
      <bpmn:incoming>F_UpdateDashboard_AnalyticsFork</bpmn:incoming>
      <bpmn:outgoing>F_AnalyticsFork_Sentiment</bpmn:outgoing>
      <bpmn:outgoing>F_AnalyticsFork_Escalation</bpmn:outgoing>
      <bpmn:outgoing>F_AnalyticsFork_Compliance</bpmn:outgoing>
      <bpmn:outgoing>F_AnalyticsFork_Resolution</bpmn:outgoing>
      <bpmn:outgoing>F_AnalyticsFork_Intent</bpmn:outgoing>
      <bpmn:outgoing>F_AnalyticsFork_Friction</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_SentimentAnalytics" name="[Analytics] Sentiment Trends and Per-Agent Breakdown">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallRecord entity
        QUERIES (records.query with aggregates and groupBy):
        1. Sentiment trend (daily):
           GROUP BY call_date → date, positive_count, neutral_count, negative_count, avg_score.
        2. Sentiment monthly:
           GROUP BY YYYY-MM → month, avg_score, positive/neutral/negative counts, total_calls.
        3. Sentiment by agent:
           GROUP BY agent_name ORDER BY avg_sentiment ASC (worst first) →
           agent_name, total_calls, positive/neutral/negative counts, avg_sentiment, negative_pct.
        IMPACT: Identifies call centre staff needing coaching based on persistent negative sentiment.
      </bpmn:documentation>
      <bpmn:incoming>F_AnalyticsFork_Sentiment</bpmn:incoming>
      <bpmn:outgoing>F_SentimentAnalytics_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_EscalationAnalytics" name="[Analytics] Escalations by Agent, Trend, Root Cause">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallRecord entity
        QUERIES (records.query with aggregates and groupBy):
        1. Escalations by agent:
           GROUP BY agent_name ORDER BY escalation_pct DESC →
           agent_name, total_calls, escalation_count, escalation_pct.
        2. Escalations trend:
           GROUP BY YYYY-MM → date, total_calls, escalation_count, escalation_pct.
        3. Escalation root-cause:
           Query CallRecord where escalation_flag=Yes. Parse triggerwords field.
           Returns top 10 trigger words and top intents by count.
        BENCHMARK: escalation_pct must be less than or equal to 10%.
        IMPACT: Root cause links trigger words to escalation drivers for targeted coaching.
      </bpmn:documentation>
      <bpmn:incoming>F_AnalyticsFork_Escalation</bpmn:incoming>
      <bpmn:outgoing>F_EscalationAnalytics_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ComplianceAnalytics" name="[Analytics] Compliance Failures by Agent and Trend">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallRecord entity
        QUERIES (records.query with aggregates and groupBy):
        1. Compliance by agent:
           GROUP BY agent_name ORDER BY compliance_fail_pct DESC →
           agent_name, total_calls, fail_count (compliance_flag=No), compliance_fail_pct.
        2. Compliance trend:
           GROUP BY YYYY-MM → date, total_calls, fail_count, compliance_fail_pct.
        KEY RULE: compliance_flag=No = AGENT FAILED. Yes = passed.
        BENCHMARK: compliance_fail_pct must be less than or equal to 5%.
        IMPACT: Persistent failures trigger re-training; high rates may need MAS reporting.
          Monthly trend validates whether coaching interventions are effective.
      </bpmn:documentation>
      <bpmn:incoming>F_AnalyticsFork_Compliance</bpmn:incoming>
      <bpmn:outgoing>F_ComplianceAnalytics_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_AnalyticsJoin" name="Synchronise: All 6 Analytics Modules Complete">
      <bpmn:documentation>
        WHAT: Waits for all 6 analytics modules. Then _build_context() in Coded Agent
          assembles the live analytics snapshot from Data Fabric for LLM Gateway grounding.
        CONTEXT FORMAT SENT TO AI:
          === Acme CALL CENTER — LIVE ANALYTICS CONTEXT ===
          Data range: [MIN(call_date)] to [MAX(call_date)] | Total calls: [N]
          --- OVERALL KPIs --- (8 metrics with benchmark values)
          --- TOP CALL INTENTS --- (top 8 by volume)
          --- AGENT PERFORMANCE --- (all agents: sentiment, escalation, resolution, compliance, repeat)
          --- MONTHLY TREND --- (by YYYY-MM: volume, sentiment, escalation, resolution)
          --- TOP TRIGGER WORDS --- (top 10 by frequency)
          --- TOP FRICTION POINTS --- (top 5 composite-scored intents)
        This grounding ensures every AI answer references real, current Data Fabric figures.
        DATA SOURCE: All queries run against CallRecord entity (beac40ee-bd6b-f111-8fcb-000d3ab36606).
      </bpmn:documentation>
      <bpmn:incoming>F_SentimentAnalytics_Join</bpmn:incoming>
      <bpmn:incoming>F_EscalationAnalytics_Join</bpmn:incoming>
      <bpmn:incoming>F_ComplianceAnalytics_Join</bpmn:incoming>
      <bpmn:incoming>F_ResolutionAnalytics_Join</bpmn:incoming>
      <bpmn:incoming>F_IntentAnalytics_Join</bpmn:incoming>
      <bpmn:incoming>F_FrictionAnalytics_Join</bpmn:incoming>
      <bpmn:outgoing>F_AnalyticsJoin_QueryAI</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="End_Complete" name="Call Analytics Process Complete">
      <bpmn:documentation>
        ALL STEPS COMPLETED:
          JSON analysis result ingested from friend's system.
          7 parallel JSON field extraction branches processed.
          CallRecord persisted to Data Fabric (atomic insert, 37+ fields including new JSON fields).
          CallFollowup rows seeded (if post-call action items generated).
          Supervisor workflow started fire-and-forget (Maestro BPMN).
          8-KPI dashboard refreshed via Data Fabric aggregations vs 6 benchmarks.
          6 analytics modules computed from Data Fabric queries.
          Grounded Q&amp;A response returned (markdown, context from live Data Fabric).
          AiUsage counters incremented.
        JSON FIELDS MAPPED:
          sentiment_avg → agent_sentiment, customer_sentiment
          audio_emotion → agent_audio_emotion, customer_audio_emotion
          talk_ratio_pct → agent_talk_pct, customer_talk_pct
          duration_sec → duration_seconds
          resolution → call_resolved_flag
          fraud_risk, fraud_reason → fraud_risk, fraud_reason
          compliance[] → compliance_flag, compliance_detail, compliance_fail_count
          triggers[] → triggerword_flag, triggerwords, trigger_count
          is_followup → is_followup_call, followup_call_evidence
          pii_digits_detected → pii_digits_detected
          summary → call_summary
          intent → call_intent1
        READY: System immediately accepts the next incoming JSON analysis result.
      </bpmn:documentation>
      <bpmn:incoming>F_GenerateResponse_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_ExtractSentiment" name="[JSON] Extract Sentiment + Audio Emotion">
      <bpmn:documentation>
        SOURCE: Friend's JSON output — sentiment_avg + audio_emotion fields
        INPUT FIELDS:
          sentiment_avg.agent    (decimal, e.g. 0.21)
          sentiment_avg.customer (decimal, e.g. 0.07)
          audio_emotion.agent    (string, e.g. "neutral")
          audio_emotion.customer (string, e.g. "neutral")
        MAPPING TO DATA FABRIC CallRecord:
          — NEW FIELD: agent_sentiment     (DECIMAL or STRING) ← sentiment_avg.agent
          — NEW FIELD: customer_sentiment  (DECIMAL or STRING) ← sentiment_avg.customer
          — NEW FIELD: agent_audio_emotion    (STRING 20) ← audio_emotion.agent
          — NEW FIELD: customer_audio_emotion (STRING 20) ← audio_emotion.customer
        NOTE: BPMN originally expected single INTEGER call_sentiment (-1/0/1).
          JSON provides per-speaker decimal sentiment + audio emotion.
          Recommend adding 4 new fields to CallRecord entity.
        USED BY: Dashboard KPIs, agent coaching, customer satisfaction tracking.
      </bpmn:documentation>
      <bpmn:incoming>F_Fork_Sentiment</bpmn:incoming>
      <bpmn:outgoing>F_Sentiment_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ClassifyIntents" name="[JSON] Extract Call Intent">
      <bpmn:documentation>
        SOURCE: Friend's JSON output — intent field
        INPUT FIELD:
          intent (string, e.g. "Claims Status" or empty)
        MAPPING TO DATA FABRIC CallRecord:
          call_intent1 (STRING 100) ← intent
          call_intent2, call_intent3 = null (JSON provides single intent only)
        NOTE: BPMN originally expected up to 3 intents in priority order.
          JSON provides single intent field.
          If multi-intent classification is needed, consider enhancing friend's JSON
          OR using Coded Agent to infer secondary intents from transcript.
        USED BY: Intent Pareto, trends, marketing opportunities, friction points.
      </bpmn:documentation>
      <bpmn:incoming>F_Fork_Intents</bpmn:incoming>
      <bpmn:outgoing>F_Intents_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DetectTriggerWords" name="[JSON] Process Trigger Events + PII Detection">
      <bpmn:documentation>
        SOURCE: Friend's JSON output — triggers array + pii_digits_detected
        INPUT FIELDS:
          triggers (array of objects):
            - time (float): timestamp in call
            - from/to (int): speaker transition
            - customer_text (string): what customer said
            - trigger_time (float): when trigger occurred
            - trigger_agent_text (string): agent text that triggered
          pii_digits_detected (boolean): true/false
        MAPPING TO DATA FABRIC CallRecord:
          triggerword_flag (CHOICE_SET_SINGLE → YesNoFlag):
            Yes(0) if triggers.length &gt; 0, else No(1)
          triggerwords (STRING 100):
            Extract keywords from triggers[].customer_text, comma-separated
          — NEW FIELD: pii_digits_detected (CHOICE_SET_SINGLE → YesNoFlag or BOOLEAN)
          — NEW FIELD: trigger_count (INTEGER): triggers.length
        NOTE: JSON provides rich trigger context (timestamps, speaker, exact text).
          Current Data Fabric schema only stores flag + word list.
          Consider adding trigger_detail (MULTILINE_TEXT) to store JSON array as text
          if full audit trail is needed.
        BENCHMARK: trigger_word_pct ≤ 3%
        IMPACT: Near-real-time alert to supervisors of escalating situations.
      </bpmn:documentation>
      <bpmn:incoming>F_Fork_TriggerWords</bpmn:incoming>
      <bpmn:outgoing>F_TriggerWords_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CheckCompliance" name="[JSON] Process Compliance Rules">
      <bpmn:documentation>
        SOURCE: Friend's JSON output — compliance array + compliance_violations
        INPUT FIELDS:
          compliance (array of 8 rule objects):
            - id: rule identifier (purpose_disclosure, recording_disclosure,
              identity_verification, no_guarantees, no_sensitive_data_insecure,
              no_remote_access, no_fund_movement, professional_conduct)
            - rule: human-readable description
            - status: PASS / FAIL / NA
            - evidence: supporting text from transcript
            - reason: explanation of failure
          compliance_violations (array of failed rule IDs):
            e.g. ["purpose_disclosure", "identity_verification"]
        MAPPING TO DATA FABRIC CallRecord:
          compliance_flag (CHOICE_SET_SINGLE → YesNoFlag):
            Yes(0) if compliance_violations.length == 0
            No(1)  if compliance_violations.length &gt; 0
          — NEW FIELD: compliance_detail (MULTILINE_TEXT 10000):
            Store full compliance JSON array as text for audit trail
          — NEW FIELD: compliance_fail_count (INTEGER):
            compliance_violations.length
        KEY RULES FROM JSON:
          purpose_disclosure: Agent identified self + stated call purpose
          recording_disclosure: Agent disclosed call may be recorded
          identity_verification: Agent verified customer identity
          no_guarantees: No promised returns/profits
          no_sensitive_data_insecure: No full card/PIN/OTP read aloud
          no_remote_access: No AnyDesk/TeamViewer instructions
          no_fund_movement: No pressure to transfer money
          professional_conduct: Professional, non-abusive behaviour
        BENCHMARK: compliance_fail_pct ≤ 5%
        IMPACT: Persistent failures may trigger MAS regulatory reporting.
          Per-rule audit trail enables targeted coaching.
      </bpmn:documentation>
      <bpmn:incoming>F_Fork_Compliance</bpmn:incoming>
      <bpmn:outgoing>F_Compliance_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GenFollowups" name="[JSON] Detect Follow-up Call + Generate Action Items">
      <bpmn:documentation>
        SOURCE: Friend's JSON output — is_followup + followup_evidence
        INPUT FIELDS:
          is_followup (boolean): Is this call itself a follow-up to prior interaction?
          followup_evidence (string): Explanation of why it is/isn't a follow-up
        PLUS: Coded Agent infers post-call action items from transcript content
        MAPPING TO DATA FABRIC CallRecord:
          — NEW FIELD: is_followup_call (CHOICE_SET_SINGLE → YesNoFlag):
            Yes(0) if is_followup == true, else No(1)
          — NEW FIELD: followup_call_evidence (MULTILINE_TEXT 2000):
            ← followup_evidence
          followup_item1/2/3 (STRING 100):
            Generated by Coded Agent analyzing transcript for post-call commitments
            e.g. "Send updated policy documents", "Process claim reimbursement"
        DOWNSTREAM: Non-empty followup_itemN seeded into CallFollowup entity
          (source=ai_generated, status=pending).
        NOTE: JSON detects if call IS a follow-up (looking backward).
          BPMN also generates action items going forward (post-call commitments).
          These are complementary concepts.
      </bpmn:documentation>
      <bpmn:incoming>F_Fork_Followups</bpmn:incoming>
      <bpmn:outgoing>F_Followups_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DetermineResolution" name="[JSON] Extract Resolution + Fraud Risk">
      <bpmn:documentation>
        SOURCE: Friend's JSON output — resolution + fraud_risk + fraud_reason
        INPUT FIELDS:
          resolution (string): "resolved" or "unresolved"
          fraud_risk (string): e.g. "low", "medium", "high"
          fraud_reason (string): explanation of fraud assessment
        MAPPING TO DATA FABRIC CallRecord:
          call_resolved_flag (CHOICE_SET_SINGLE → YesNoFlag):
            Yes(0) if resolution == "resolved"
            No(1)  if resolution == "unresolved"
          — NEW FIELD: fraud_risk (STRING 20): ← fraud_risk
          — NEW FIELD: fraud_reason (MULTILINE_TEXT 2000): ← fraud_reason
        NOTE: JSON provides single resolution field (resolved/unresolved).
          BPMN originally expected 4 flags (resolved, escalation, preverified, repeat).
          Escalation, preverified, and repeat_call flags are NOT in the JSON
          and must be inferred by Coded Agent from transcript if needed.
        BENCHMARKS: resolution_pct ≥ 80%
        IMPACT: Unresolved calls + high fraud risk trigger supervisor alerts.
      </bpmn:documentation>
      <bpmn:incoming>F_Fork_Resolution</bpmn:incoming>
      <bpmn:outgoing>F_Resolution_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GenSummary" name="[JSON] Extract Call Summary + Talk Ratio">
      <bpmn:documentation>
        SOURCE: Friend's JSON output — summary + talk_ratio_pct + duration_sec + recording
        INPUT FIELDS:
          summary (string): Plain-English call summary (may be empty)
          talk_ratio_pct.AGENT (decimal): % of time agent spoke, e.g. 28.7
          talk_ratio_pct.CUSTOMER (decimal): % of time customer spoke, e.g. 71.3
          duration_sec (decimal): Call duration in seconds, e.g. 689.6
          recording (string): MP3 filename, e.g. "tmpi70znh6_.mp3"
        MAPPING TO DATA FABRIC CallRecord:
          call_summary (MULTILINE_TEXT 10000): ← summary
          file_name (STRING 100): ← recording (mp3 filename)
          — NEW FIELD: agent_talk_pct (DECIMAL): ← talk_ratio_pct.AGENT
          — NEW FIELD: customer_talk_pct (DECIMAL): ← talk_ratio_pct.CUSTOMER
          — NEW FIELD: duration_seconds (DECIMAL): ← duration_sec
        NOTE: If summary is empty, Coded Agent can generate one from transcript.
          Talk ratio is valuable for coaching — dominant customer talk time
          may indicate agent passivity or customer frustration.
        USED BY: Call detail page, supervisor review, follow-up triage.
      </bpmn:documentation>
      <bpmn:incoming>F_Fork_Summary</bpmn:incoming>
      <bpmn:outgoing>F_Summary_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ResolutionAnalytics" name="[Analytics] Resolution, Repeat Calls, Pre-Verified Trends">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallRecord entity
        QUERIES (records.query with aggregates and groupBy):
        1. Resolution overview:
           COUNT(Id), COUNT(call_resolved_flag=Yes), COUNT(repeatcall_flag=Yes),
           resolution_pct, repeat_call_pct.
        2. Resolution trend (monthly):
           GROUP BY YYYY-MM of call_date → date, total_calls, resolved_count, resolution_pct.
        3. Repeat calls trend (monthly):
           GROUP BY YYYY-MM → date, total_calls, repeat_count, repeat_pct.
        4. Repeat calls by agent:
           GROUP BY agent_name ORDER BY repeat_pct DESC.
        5. Pre-verified trend (monthly):
           GROUP BY YYYY-MM → date, total_calls, preverified_count, preverified_pct.
        BENCHMARKS: resolution ≥ 80%, preverified ≥ 80%, repeat calls ≤ 20%.
        IMPACT: High repeat rates indicate persistent unresolved issues — targets for
          self-service improvement or first-call resolution coaching.
      </bpmn:documentation>
      <bpmn:incoming>F_AnalyticsFork_Resolution</bpmn:incoming>
      <bpmn:outgoing>F_ResolutionAnalytics_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_IntentAnalytics" name="[Analytics] Intent Pareto, Trends, Marketing Opportunities">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallRecord entity
        QUERIES (records.query with aggregates and groupBy):
        1. Intent Pareto:
           GROUP BY call_intent1 ORDER BY COUNT DESC →
           intent, count, pct, cumulative_pct, avg_sentiment, escalation_pct, repeat_call_pct.
           cumulative_pct enables 80/20 Pareto analysis.
        2. Intent trend:
           GROUP BY call_date + call_intent1 → date, intent, count.
        3. Marketing opportunities:
           Covers: New Business, Renewals, Policy Info, Cancellations, Claims Status.
           SCORE = (intent_base x 40%) + (positive_pct x 35%) + (resolved_pct x 25%)
           BASE SCORES: New Business=100, Renewals=85, Policy Info=65, Cancellations=50, Claims=40.
           LEVELS: High (score 65+), Medium (45-64), Low (below 45).
           ACTIONS: New Business=CI/TPD/NCD riders, Renewals=sum increase+riders,
             Policy Info=CI+hospitalisation upgrade, Cancellations=premium holiday/paid-up,
             Claims=protection gap review/personal accident.
        IMPACT: Identifies cross-sell and upsell windows during service interactions.
      </bpmn:documentation>
      <bpmn:incoming>F_AnalyticsFork_Intent</bpmn:incoming>
      <bpmn:outgoing>F_IntentAnalytics_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_FrictionAnalytics" name="[Analytics] Friction Points and Trigger Word Frequency">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallRecord entity
        QUERIES (records.query with aggregates and groupBy):
        1. Friction Points:
           COMPOSITE SCORE per intent = (negative_pct x 40%) + (escalation_pct x 35%) + (repeat_call_pct x 25%)
           GROUP BY call_intent1 HAVING COUNT(*) ≥ 3 (statistical minimum).
           Returns top 10 sorted by friction_score DESC:
             intent, total_calls, avg_sentiment, negative_pct, escalation_pct,
             repeat_call_pct, unresolved_pct, friction_score (0-100), rank.
           HIGH-FRICTION INTENTS are targets for: automation, call centre staff training, process improvement.
        2. Trigger word counts:
           Query CallRecord where triggerword_flag=Yes. Parse triggerwords field.
           Returns top 20 words by frequency.
        3. Trigger word trend (monthly):
           GROUP BY YYYY-MM → date, total_calls, trigger_count, trigger_pct. Benchmark ≤ 3%.
        AI CONTEXT: Top 5 friction points and top 10 trigger words included in
          _build_context() payload sent to Coded Agent for Q&amp;A grounding.
      </bpmn:documentation>
      <bpmn:incoming>F_AnalyticsFork_Friction</bpmn:incoming>
      <bpmn:outgoing>F_FrictionAnalytics_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GenerateAIResponse" name="[Coded Agent] Generate Contextual Analytics Response">
      <bpmn:documentation>
        PRODUCT: Coded Agent (call-center-ai-agent)
        TOOL: ask(question, context) — grounded Q&amp;A over live Data Fabric data
        STEPS:
          1. _build_context(): 6 Data Fabric queries assembled into plain-text analytics snapshot:
             - Total calls, date range
             - 8 KPIs with benchmark comparisons
             - Top call intents by volume
             - Per-agent performance (sentiment, escalation, resolution, compliance, repeat)
             - Monthly trends (volume, sentiment, escalation, resolution)
             - Top trigger words and top 5 friction points
          2. Sends to LLM Gateway via UiPath AI:
               prompt = f"DATA CONTEXT:\n{context}\n\nQUESTION: {question}"
          3. SYSTEM PROMPT instructs the AI to:
               Act as expert call centre analytics AI for Acme.
               Back every answer with specific numbers from the context.
               Format in markdown: headers, bold key figures, bullet points.
               Be direct and actionable for operational decision-making.
               Apply business rules:
                 compliance_flag='No' = AGENT failed (not the customer).
                 call_sentiment: 1=Positive, 0=Neutral, -1=Negative.
               Know agent specialisations:
                 Sam=Claims/Grievances, John=Policy Services,
                 David=Escalations/Quality, Mike=New Business/Renewals,
                 Mary=Billing/Amendments.
           4. _log_ai_call(): UPSERT into AiUsage Data Fabric entity
              ENTITY: AiUsage (45af032d-bb6b-f111-8fcb-000d3ab36606)
              PATTERN: Query by record_key='singleton'. If exists → update. If not → insert.
              FIELDS UPDATED:
                - calls_today: increment by 1; reset to 1 if period_date != today
                - total_calls: increment by 1 (never reset)
                - period_date: set to today if changed
                - last_call_at: UTC now
                - last_model: model name used
                - last_endpoint: 'ask'
           5. Returns: { question, answer (markdown), data_context (raw text) }.
         MODEL: UiPath LLM Gateway [DEFAULT] (gemini-2.5-flash-equivalent)
         AUTH: Inherited from UiPath LLM Gateway connection (no API key in code).
      </bpmn:documentation>
      <bpmn:incoming>F_QueryAI_GenerateResponse</bpmn:incoming>
      <bpmn:outgoing>F_GenerateResponse_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_SupervisorReview" name="Supervisor Reviews Pending AI Follow-up Items">
      <bpmn:documentation>
        WHAT: Supervisor opens the Follow-ups panel in the Coded App dashboard.
        DATA SOURCE: Data Fabric CallFollowup entity (993c2c06-be6b-f111-8fcb-000d3ab36606)
        PER-CALL VIEW: Query CallFollowup filtered by callid + join CallRecord for caller context.
        GLOBAL QUEUE: Query CallFollowup with filters:
          - status (CHOICE_SET_SINGLE → FollowupStatus)
          - source (CHOICE_SET_SINGLE → FollowupSource)
          - priority (CHOICE_SET_SINGLE → FollowupPriority)
          - assigned_to, due_date ranges, search on text/reason.
          Sort: overdue first, then status order, then date.
        GLOBAL SUMMARY: Aggregated query on CallFollowup:
          total, pending, approved, in_progress, completed, rejected,
          overdue (due_date past + status active), due_soon (within 3 days),
          completion_rate = completed / (approved + in_progress + completed) * 100.
        EACH ITEM SHOWS: text, reason, source, status, priority,
          is_overdue, days_overdue, caller_name, policy_number, call_summary,
          call_intents, escalation_flag, compliance_flag, call_resolved_flag.
        MANUAL ITEM: Coded App allows adding manual follow-ups (source=manual, auto-approved).
        EDIT/DELETE: Coded App updates/deletes CallFollowup records directly.
      </bpmn:documentation>
      <bpmn:incoming>F_HasFollowups_Yes</bpmn:incoming>
      <bpmn:outgoing>F_Review_ApproveRejectGW</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_ApproveReject" name="Supervisor Decision: Approve or Reject?">
      <bpmn:documentation>
        STATE MACHINE: pending(0) -&gt; approved(1) -&gt; in_progress(3) -&gt; completed(4)
                       pending(0) -&gt; rejected(2) (terminal)
        RULE: pending items CANNOT jump to in_progress or completed directly.
          Enforced by Coded App / Maestro BPMN validation.

        APPROVE: Update CallFollowup record:
          status = approved (FollowupStatus NumberId=1)
          approved_by = supervisor name
          approved_at = UTC now
          priority, assigned_to, due_date = captured from form

        REJECT: Update CallFollowup record:
          status = rejected (FollowupStatus NumberId=2)
          approved_by = supervisor name
          approved_at = UTC now
          Stays in Data Fabric for audit. Excluded from completion_rate.
          Queryable: records.query with filter status=rejected.
      </bpmn:documentation>
      <bpmn:incoming>F_Review_ApproveRejectGW</bpmn:incoming>
      <bpmn:outgoing>F_ApproveReject_Approve</bpmn:outgoing>
      <bpmn:outgoing>F_ApproveReject_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_AssignDetails" name="Assign Priority, Agent, and Due Date to Approved Follow-up">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallFollowup entity
        FIELDS SET ON APPROVAL (update record):
          status      = approved (FollowupStatus NumberId=1)
          priority    : low(0) | medium(1) | high(2) — determines queue sort order
          assigned_to : agent name responsible for the action (STRING 50)
          due_date    : target completion date (DATE)
            is_overdue = due_date is past AND status not in (completed, rejected)
            days_overdue = today minus due_date (integer)
          approved_by : supervisor name (STRING 50)
          approved_at : UTC now (DATETIME)
        CAPTURED VIA: Coded App form OR HITL task form in Maestro BPMN.
        STATUS TRANSITION: pending(0) -&gt; approved(1).
        AUDIT: approved_by + approved_at tracked on CallFollowup record.
        NOTE: Manual items (source=manual) are auto-approved — skip this task.
      </bpmn:documentation>
      <bpmn:incoming>F_ApproveReject_Approve</bpmn:incoming>
      <bpmn:outgoing>F_AssignDetails_TrackProgress</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_RejectFollowup" name="Mark Follow-up Rejected (Audit Trail Preserved)">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallFollowup entity
        FIELDS SET: status=rejected (FollowupStatus NumberId=2), approved_by, approved_at=UTC now.
        EFFECT:
          Counted in GlobalSummary.rejected.
          Excluded from completion_rate = completed / (approved + in_progress + completed) x 100.
          Removed from overdue and due_soon active queues.
          Preserved in Data Fabric for audit (queryable by status=rejected).
        OPERATION: Coded App or Maestro BPMN task updates the CallFollowup record directly.
      </bpmn:documentation>
      <bpmn:incoming>F_ApproveReject_Reject</bpmn:incoming>
      <bpmn:outgoing>F_Reject_UpdateDashboard</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_TrackProgress" name="Agent Executes Follow-up Action (in_progress)">
      <bpmn:documentation>
        WHAT: Assigned call centre staff member works on the approved follow-up action.
        DATA SOURCE: Data Fabric CallFollowup entity
        STATUS TRANSITION: approved(1) -&gt; in_progress(3).
        OPERATION: Coded App or Maestro BPMN updates CallFollowup.status to in_progress.
        VALIDATION: pending(0) -&gt; in_progress(3) is rejected by state machine.
        WHILE IN_PROGRESS:
          is_overdue = True if due_date before today and not completed/rejected.
          days_overdue = today minus due_date.
          Overdue items surface first in CallFollowup queries (ORDER BY is_overdue DESC).
          GlobalSummary.overdue = count where past due and still active.
          GlobalSummary.due_soon = count where due within next 3 days and active.
        COMPLETION RATE: completed / (approved + in_progress + completed) x 100.
        EXAMPLE ACTIONS: Email policy docs, process claim reimbursement,
          schedule callback, escalate to underwriting team.
      </bpmn:documentation>
      <bpmn:incoming>F_AssignDetails_TrackProgress</bpmn:incoming>
      <bpmn:outgoing>F_TrackProgress_ProgressGW</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_ProgressStatus" name="Is the Follow-up Action Complete?">
      <bpmn:documentation>
        COMPLETED path: status becomes 'completed', capture completion_notes and timestamp.
        STILL ACTIVE path: item remains 'in_progress', stays in queue, may become overdue.
        GlobalSummary.due_soon: due within next 3 days AND status still active.
        GlobalSummary.overdue:  due_date in the past AND status still active.
      </bpmn:documentation>
      <bpmn:incoming>F_TrackProgress_ProgressGW</bpmn:incoming>
      <bpmn:outgoing>F_Progress_Done</bpmn:outgoing>
      <bpmn:outgoing>F_Progress_Active</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_MarkCompleted" name="Mark Follow-up Completed — Record Notes and Timestamp">
      <bpmn:documentation>
        DATA SOURCE: Data Fabric CallFollowup entity
        STATUS TRANSITION: in_progress(3) -&gt; completed(4).
        OPERATION: Coded App or Maestro BPMN updates CallFollowup record:
          status = completed (FollowupStatus NumberId=4)
          completed_at = UTC now (DATETIME)
          completion_notes = description of action taken (MULTILINE_TEXT 2000)
        EXAMPLE NOTES:
          "Policy document emailed to customer on 2025-06-17."
          "Claim reimbursement SGD 1,240 processed. Ref: CLM-2025-04521."
          "Callback completed — customer confirmed receipt of amendment letter."
        EFFECT: Increases GlobalSummary.completed, increases completion_rate,
          removes from overdue/due_soon counts.
        SUPERVISOR QA: Reads completion_notes to confirm all commitments fulfilled.
      </bpmn:documentation>
      <bpmn:incoming>F_Progress_Done</bpmn:incoming>
      <bpmn:outgoing>F_Completed_UpdateDashboard</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_QueryAI" name="Supervisor Submits Question to AI Insights Panel">
      <bpmn:documentation>
        WHAT: Supervisor types or selects a question in the AI Insights panel of the Coded App dashboard.
        ENDPOINT: Direct call to Coded Agent ask() tool via LLM Gateway.
        SUGGESTED QUESTIONS:
          "Why are customers calling most frequently?"
          "Which agent has the highest escalation rate and why?"
          "Are there automation opportunities based on call patterns?"
          "What are the top drivers of negative sentiment?"
          "Which call intents have the lowest resolution rate?"
          "What compliance issues are most common?"
          "Are there upsell or cross-sell opportunities in recent calls?"
          "What are the top 3 friction points for customers?"
          "How has call volume and sentiment trended month over month?"
          "Which agent needs the most coaching and why?"
        AI USAGE TRACKING (AiUsage Data Fabric entity, singleton row):
          ENTITY: AiUsage (45af032d-bb6b-f111-8fcb-000d3ab36606)
          PATTERN: Query record_key='singleton'. Update or insert.
          calls_today: increments per request; resets when period_date changes.
          total_calls: all-time cumulative count (never reset).
          last_call_at, last_model, last_endpoint: most recent request metadata.
        USAGE QUERY: Data Fabric records.query on AiUsage entity.
      </bpmn:documentation>
      <bpmn:incoming>F_AnalyticsJoin_QueryAI</bpmn:incoming>
      <bpmn:outgoing>F_QueryAI_GenerateResponse</bpmn:outgoing>
